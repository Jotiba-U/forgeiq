# ForgeIQ Backend Environment Variables - Template Example

# Application
APP_NAME=ForgeIQ
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/forgeiq
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/forgeiq

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=forgeiq_documents

# Google Gemini AI
GOOGLE_API_KEY=your-gemini-api-key-here

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CORS
FRONTEND_URL=http://localhost:3000
